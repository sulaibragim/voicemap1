rules_version = '2';

// ================================================================
// VoiceMap — Firestore Security Rules
// Структура: users/{uid}/recordings, notes (subcollections)
// Владелец определяется по uid в пути — userId в полях не нужен.
// ================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Вспомогательные функции ──────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Проверяет, что строковое поле присутствует и не длиннее maxLen
    function validStr(data, field, maxLen) {
      return field in data &&
             data[field] is string &&
             data[field].size() <= maxLen;
    }

    // Опциональное строковое поле — если есть, то не длиннее maxLen
    function validOptStr(data, field, maxLen) {
      return !(field in data) ||
             (data[field] is string && data[field].size() <= maxLen);
    }

    // Опциональный список — если есть, то не длиннее maxSize
    function validOptList(data, field, maxSize) {
      return !(field in data) ||
             (data[field] is list && data[field].size() <= maxSize);
    }

    // ── Валидаторы типов ─────────────────────────────────────────

    function isValidRecording(data) {
      return validStr(data, 'id',       100) &&
             validStr(data, 'title',    200) &&
             validStr(data, 'date',      50) &&
             validStr(data, 'duration',  30) &&
             ('tags' in data && data.tags is list && data.tags.size() <= 50) &&
             validStr(data, 'summary', 50000) &&
             ('transcript' in data && data.transcript is list && data.transcript.size() <= 5000) &&
             validOptStr(data, 'audioUrl', 2000) &&
             validOptList(data, 'ideas', 200) &&
             validOptList(data, 'actionItems', 200) &&
             validOptList(data, 'mentions', 200) &&
             validOptList(data, 'keyMoments', 200) &&
             validOptList(data, 'openQuestions', 200) &&
             validOptList(data, 'bigQuestions', 200) &&
             validOptList(data, 'condensedTranscript', 5000) &&
             validOptList(data, 'appendAudios', 50) &&
             validOptList(data, 'participants', 50) &&
             validOptList(data, 'richActionItems', 200) &&
             validOptStr(data, 'r2Key', 500);
    }

    function isValidNote(data) {
      return validStr(data, 'id',      100) &&
             validStr(data, 'content', 5000) &&
             validStr(data, 'date',    50) &&
             ('type' in data && data.type in ['Идея', 'Задача', 'Напоминание']);
    }

    // ── Правила доступа к документам ─────────────────────────────

    // Профиль пользователя. Поле plan (тариф) назначает только сервер через
    // Admin SDK — иначе лимит расшифровки обходился бы одной правкой документа.
    // ВАЖНО: клиент пишет профиль через setDoc(..., {merge: true}), поэтому
    // request.resource.data — это документ ПОСЛЕ слияния. Проверять «поля plan нет»
    // на update нельзя (оно там будет), проверяем «plan не изменился».
    match /users/{uid} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && !('plan' in request.resource.data);
      allow update: if isOwner(uid) &&
                       request.resource.data.get('plan', '') == resource.data.get('plan', '');
      allow delete: if isOwner(uid);
    }

    // Счётчик израсходованных секунд расшифровки за месяц (users/{uid}/usage/{YYYY-MM}).
    // Пишет исключительно сервер (Admin SDK обходит эти правила), клиент только читает.
    match /users/{uid}/usage/{month} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // Recordings
    match /users/{uid}/recordings/{recordingId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && isValidRecording(request.resource.data);
      allow update: if isOwner(uid) && isValidRecording(request.resource.data);
      allow delete: if isOwner(uid);
    }

    // Notes
    match /users/{uid}/notes/{noteId} {
      allow read:   if isOwner(uid);
      allow create: if isOwner(uid) && isValidNote(request.resource.data);
      allow update: if isOwner(uid) && isValidNote(request.resource.data);
      allow delete: if isOwner(uid);
    }

    // Запрещаем всё остальное явно
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
