# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase Admin (для верификации токенов) ───────────────────────────────────
# JSON сервисного аккаунта Firebase — скопировать всё содержимое в одну строку
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=gen-lang-client-0179752723

# ⚠️ ТОЛЬКО ДЛЯ ЛОКАЛЬНОЙ РАЗРАБОТКИ. Разрешает дев-фолбэк аутентификации, который
# декодирует JWT без проверки подписи (когда нет FIREBASE_SERVICE_ACCOUNT_JSON и NODE_ENV != production).
# Без этой переменной (или при её отсутствии) сервер отвечает 401 — это безопасное поведение по умолчанию.
# НИКОГДА не устанавливай true в .env.production / на проде.
ALLOW_INSECURE_DEV_AUTH=false

# ── Лимиты расшифровки (минут в календарный месяц на пользователя) ────────────
# Необязательные: без них действуют значения по умолчанию из server/lib/usage.ts
# (free 120, pro 1200, team 3600). Задавать здесь, чтобы менять лимит на Railway
# без пересборки. Тариф пользователя лежит в Firestore: users/{uid}.plan
PLAN_FREE_MINUTES=120
PLAN_PRO_MINUTES=1200
PLAN_TEAM_MINUTES=3600

# Сколько токенов Gemini начисляет за секунду аудио — по этому числу считается
# фактический расход из usageMetadata. Менять только если Google изменит тарификацию.
GEMINI_AUDIO_TOKENS_PER_SEC=32

# ── Cloudflare R2 (аудио файлы) ───────────────────────────────────────────────
R2_ENDPOINT=https://9ea56d6fa740d5d7d40e254aefc288a7.r2.cloudflarestorage.com
R2_BUCKET_NAME=voicemap
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_URL=https://pub-9e5aae7f9e314fa0ab278ea9c27bc679.r2.dev

# ── Сервер ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS (разрешённые домены) ──────────────────────────────────────────────────
# Railway даст домен вида: https://voicemap-production.up.railway.app
# Capacitor: обязательно добавить capacitor://localhost
ALLOWED_ORIGINS=https://your-app.up.railway.app,capacitor://localhost,http://localhost

# ── Фронтенд (для Capacitor сборки) ───────────────────────────────────────────
# Адрес твоего Railway сервера — вставится в Vite билд
# В .env.local для разработки оставь пустым (Vite proxy работает)
VITE_API_URL=https://your-app.up.railway.app
