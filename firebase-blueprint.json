{
  "entities": {
    "Recording": {
      "title": "Recording",
      "description": "A voice recording with AI-generated transcript, summary, tasks, and promises.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this recording."
        },
        "title": {
          "type": "string",
          "description": "The title of the recording."
        },
        "date": {
          "type": "string",
          "description": "The date string of the recording."
        },
        "duration": {
          "type": "string",
          "description": "The duration of the recording."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags associated with the recording."
        },
        "summary": {
          "type": "string",
          "description": "AI-generated summary of the recording."
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "assignee": { "type": "string" },
              "deadline": { "type": "string" }
            }
          },
          "description": "Tasks extracted from the recording."
        },
        "promises": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Promises extracted from the recording."
        },
        "transcript": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "speaker": { "type": "string" },
              "timestamp": { "type": "string" },
              "text": { "type": "string" }
            }
          },
          "description": "The transcript of the recording."
        },
        "audioUrl": {
          "type": "string",
          "description": "Optional URL to the audio file."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the recording was created."
        }
      },
      "required": ["userId", "title", "date", "duration", "tags", "summary", "tasks", "promises", "transcript", "createdAt"]
    }
  },
  "firestore": {
    "/recordings/{recordingId}": {
      "schema": { "$ref": "Recording" },
      "description": "Stores user recordings."
    }
  }
}
